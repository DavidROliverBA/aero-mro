# Supabase — publishable (client-safe) key. Copy to .env.local
VITE_SUPABASE_URL=https://biffxhtytzdcfsbxscwm.supabase.co
VITE_SUPABASE_KEY=sb_publishable_...

# Optional: a Claude API key can also be pasted into the app UI at runtime instead.
# VITE_ANTHROPIC_API_KEY=sk-ant-...

# Optional — server-side only (NEVER VITE_-prefixed), used by mcp/server.ts:
# SUPABASE_SERVICE_KEY=...

# Optional — Playwright test user (create via Settings → User management):
# UX_TEST_EMAIL=uxtest@aeromro.demo
# UX_TEST_PASSWORD=...

# Optional — route AI calls via workers/ai-proxy instead of a runtime key:
# VITE_AI_PROXY_URL=https://aero-mro-ai-proxy.<account>.workers.dev
